generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  /** "superadmin" | "subadmin" (legacy "admin" treated as superadmin). */
  role         String   @default("superadmin")
  /** Checkbox permissions for subadmin. Ignored for superadmin (full access). */
  permissions  Json     @default("[]")
  /** Optional link to a role template (Roles & Permissions page). */
  roleDefinitionId String?
  roleDefinition   AdminRoleDefinition? @relation(fields: [roleDefinitionId], references: [id], onDelete: SetNull)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([roleDefinitionId])
}

/** Reusable role templates shown on Admin → Roles & Permissions. */
model AdminRoleDefinition {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions Json     @default("[]")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       AdminUser[]
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageTemplate {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  status          String   @default("draft")
  content         Json
  seoTitle        String?
  seoDescription  String?
  canonicalUrl    String?
  ogImageUrl      String?
  publishAsNews   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model NewsPost {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  excerpt        String?
  content        Json
  featureImage   String?
  status         String   @default("draft")
  seoTitle       String?
  seoDescription String?
  authorName     String?
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  comments       NewsComment[]
  ratings        NewsRating[]
}

model NewsComment {
  id        String   @id @default(cuid())
  newsId    String
  news      NewsPost @relation(fields: [newsId], references: [id], onDelete: Cascade)
  name      String
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model NewsRating {
  id        String   @id @default(cuid())
  newsId    String
  news      NewsPost @relation(fields: [newsId], references: [id], onDelete: Cascade)
  value     Int
  createdAt DateTime @default(now())
}

model HomeRating {
  id        String   @id @default(cuid())
  value     Int
  email     String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

/// Ratings for dynamic CMS pages (calculator clones, article pages on /[slug], etc.)
model ToolRating {
  id        String   @id @default(cuid())
  context   String
  value     Int
  createdAt DateTime @default(now())

  @@index([context])
}

model AdSlot {
  id        String   @id @default(cuid())
  slotKey   String   @unique
  title     String
  code      String?
  isEnabled Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  tags      String[]
  createdAt DateTime @default(now())
}

model EmailSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  tags      String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actor     String
  action    String
  target    String
  payload   Json?
  createdAt DateTime @default(now())
}

/// Contact form submissions from /contact
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  topic     String   @default("general")
  status    String   @default("new")
  etaHours  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([topic, createdAt])
  @@index([createdAt])
}

/// Privacy / Terms / Disclaimer (and other legal) pages — admin CMS
model LegalPage {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  content        Json
  seoTitle       String?
  seoDescription String?
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, updatedAt])
}

/// Home / PUBG public reviews (admin moderate)
model Testimonial {
  id         String    @id @default(cuid())
  name       String
  email      String?
  rating     Int
  message    String
  game       String
  phoneModel String?
  showName   Boolean   @default(true)
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  approvedAt DateTime?

  @@index([status, createdAt])
  @@index([game, status, approvedAt])
  @@index([status, approvedAt, createdAt])
}
